{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ordinary.sh/atlas/schemas/addon/v1.0.0",
  "title": "Atlas Addon Steps Schema",
  "description": "Schema for addons/*/steps.json",
  "type": "object",
  "required": ["id", "name", "version", "steps"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique addon identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable addon name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the addon"
    },
    "description": {
      "type": "string",
      "description": "Addon description"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type", "action"],
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string",
            "enum": ["package", "file", "config", "script", "command"],
            "description": "Step operation type"
          },
          "action": {
            "type": "string",
            "minLength": 1,
            "description": "Action to perform"
          },
          "target": {
            "type": "string",
            "description": "Target file or package"
          },
          "content": {
            "description": "Content for the operation"
          },
          "options": {
            "type": "object",
            "additionalProperties": true,
            "description": "Additional options for the step"
          }
        }
      }
    },
    "requirements": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "node": {
          "type": "string",
          "description": "Required Node.js version"
        },
        "pnpm": {
          "type": "string",
          "description": "Required pnpm version"
        }
      }
    }
  }
}
