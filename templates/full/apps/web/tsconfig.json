{
  "extends": "@atlas/config-typescript/nextjs",
  "compilerOptions": {
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "~/*": ["./src/*"],
      "@atlas/ui": ["../../packages/ui/src"],
      "@atlas/query": ["../../packages/query/src"],
      "@atlas/api-client": ["../../packages/api-client/src"],
      "@atlas/design-system": ["../../packages/design-system/src"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "src/types/**/*.d.ts"],
  "exclude": ["node_modules"]
}
