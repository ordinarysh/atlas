# Atlas Full Template - Environment Variables
# Copy this to .env.local and fill in your values
# Never commit real secrets to version control!

#──────────────────────────────────────────────────────────────────────────────
# Core Environment
#──────────────────────────────────────────────────────────────────────────────

# Node.js environment (development | test | production)
NODE_ENV=development

#──────────────────────────────────────────────────────────────────────────────  
# Public Variables (NEXT_PUBLIC_*)
# These are exposed to the client and should not contain secrets
#──────────────────────────────────────────────────────────────────────────────

# Application configuration
NEXT_PUBLIC_APP_NAME=Atlas App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api

#──────────────────────────────────────────────────────────────────────────────
# Server-Only Variables (optional - uncomment if implementing features)
# These are never exposed to the client browser bundle
#──────────────────────────────────────────────────────────────────────────────

# Database (optional - only if implementing data layer)
# DATABASE_URL=postgresql://username:password@localhost:5432/database_name