# Atlas Full Template - Environment Variables
# Copy this to .env.local and fill in your values
# Never commit real secrets to version control!

#──────────────────────────────────────────────────────────────────────────────
# Core Environment
#──────────────────────────────────────────────────────────────────────────────

# Node.js environment (development | test | production)
NODE_ENV=development

#──────────────────────────────────────────────────────────────────────────────  
# Public Variables (NEXT_PUBLIC_*)
# These are exposed to the client and should not contain secrets
#──────────────────────────────────────────────────────────────────────────────

# Application configuration
NEXT_PUBLIC_APP_NAME=Atlas App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=/api

#──────────────────────────────────────────────────────────────────────────────
# Server-Only Variables (optional - uncomment if implementing features)
# These are never exposed to the client browser bundle
#──────────────────────────────────────────────────────────────────────────────

# Database (optional - only if implementing data layer)
# DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Rate Limiting Configuration
# Provider: "memory" for development/single-instance, "redis" for production
RATE_LIMIT_PROVIDER=memory

# Maximum requests per window (default: 60)
RATE_LIMIT_MAX=60

# Time window in milliseconds (default: 60000 = 1 minute)  
RATE_LIMIT_WINDOW_MS=60000

# Key prefix for namespacing different environments/endpoints (default: "api")
RATE_LIMIT_PREFIX=api

# Trust proxy headers for IP extraction (default: false)
# Set to true when behind a trusted proxy/CDN (enables x-real-ip/cf-connecting-ip)
TRUST_PROXY=false

# Redis URL (required when RATE_LIMIT_PROVIDER=redis)
# REDIS_URL=redis://localhost:6379

#──────────────────────────────────────────────────────────────────────────────
# Security Configuration
#──────────────────────────────────────────────────────────────────────────────

# Enable security middleware (default: false for development)
# Set to true in production to enable security headers, CORS, and request logging
ENABLE_SECURITY_MIDDLEWARE=false

# Allowed origins for CORS (default: "*" for development)
# In production, set to your specific domains: "https://yourdomain.com,https://admin.yourdomain.com"
ALLOWED_ORIGINS=*