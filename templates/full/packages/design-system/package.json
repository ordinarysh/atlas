{
  "name": "@atlas/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal semantic token layer for Tailwind v4",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css",
    "./preset": {
      "import": "./dist/preset.js",
      "types": "./dist/preset.d.ts"
    }
  },
  "files": [
    "dist",
    "styles.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp src/styles.css dist/styles.css",
    "dev": "tsc --watch",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@atlas/config-eslint": "workspace:*",
    "@atlas/config-prettier": "workspace:*",
    "@atlas/config-typescript": "workspace:*",
    "@types/node": "^20.19.10",
    "eslint": "^9.33.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.18.0",
    "pnpm": "10.14.0"
  }
}
