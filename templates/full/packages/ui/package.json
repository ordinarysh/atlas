    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "typescript-eslint": "^8.39.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
