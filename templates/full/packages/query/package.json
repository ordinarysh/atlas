{
  "name": "@atlas/query",
  "version": "0.0.0",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./examples": {
      "import": "./src/examples/index.ts",
      "types": "./src/examples/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@atlas/api-client": "workspace:*",
    "@atlas/todos-domain": "workspace:*",
    "@tanstack/react-query": "5.84.1",
    "@tanstack/react-query-devtools": "5.84.1",
    "react": "19.1.0",
    "react-error-boundary": "^6.0.0",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@atlas/config-eslint": "workspace:*",
    "@atlas/config-prettier": "workspace:*",
    "@atlas/config-typescript": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9",
    "jsdom": "^25.0.0",
    "typescript": "^5",
    "typescript-eslint": "^8.39.0",
    "vite": "^7.1.2",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "engines": {
    "node": ">=22.18.0",
    "pnpm": "10.14.0"
  }
}
