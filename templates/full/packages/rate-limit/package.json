{
  "name": "@atlas/rate-limit",
  "version": "0.1.0",
  "private": true,
  "description": "Provider-agnostic rate limiting with in-memory and Redis support",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {},
  "devDependencies": {
    "@atlas/config-eslint": "workspace:*",
    "@atlas/config-prettier": "workspace:*",
    "@atlas/config-typescript": "workspace:*",
    "@types/node": "^20",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.33.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.18.0",
    "pnpm": "10.14.0"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "README.md"
  ]
}
