# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies - CRITICAL: Must be excluded from templates
node_modules/
**/node_modules/
.pnpm-store/
**/.pnpm-store/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build outputs - These are generated by users
dist/
**/dist/
build/
**/build/
.next/
**/.next/
out/
**/out/
.vercel
.netlify

# Testing artifacts
coverage/
**/coverage/
playwright-report/
**/playwright-report/
test-results/
**/test-results/

# Build caches
.turbo/
**/.turbo/
.cache/
**/.cache/
.vite/
**/.vite/

# TypeScript build artifacts
*.tsbuildinfo
**/*.tsbuildinfo
tsconfig.tsbuildinfo

# Lockfiles - Templates should not ship with lockfiles
pnpm-lock.yaml
package-lock.json
yarn.lock
**/pnpm-lock.yaml
**/package-lock.json
**/yarn.lock

# Environment files (only .env.example should be committed)
.env
.env.*
!.env.example
!.env.sample
.env.local
.env.production
.env.development

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# Temporary files
*.tmp
*.temp
.tmp/
.temp/
tmp/
temp/

# Security
*.pem
*.key
*.cert
*.crt

# Next.js specific
next-env.d.ts