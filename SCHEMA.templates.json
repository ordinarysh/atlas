{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ordinary.sh/atlas/schemas/templates/v1.0.0",
  "title": "Atlas Manifest Schema",
  "description": "Schema for templates/manifest.json",
  "type": "object",
  "required": ["version", "templates"],
  "additionalProperties": true,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the manifest"
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "type"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Unique template identifier"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable template name"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "Template description"
          },
          "type": {
            "type": "string",
            "enum": ["core", "web", "api", "mobile"],
            "description": "Template category"
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Template dependencies"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Searchable tags"
          }
        }
      }
    }
  }
}
