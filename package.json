{
  "name": "@ordinary/atlas",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:staged": "tsc --noEmit --pretty false",
    "validate": "tsx scripts/validate.ts",
    "validate:versions": "tsx scripts/validate-versions.ts",
    "build:release": "tsx scripts/build-release.ts",
    "generate:presets": "tsx scripts/generate-presets.ts",
    "generate:snapshot": "tsx scripts/generate-snapshot.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "BUILD_SMOKE=skip vitest run",
    "clean:templates": "tsx scripts/clean-templates.ts",
    "smoke:test": "tsx scripts/smoke-test.ts",
    "smoke:full": "tsx scripts/smoke-test.ts full 0.0.0",
    "check-all": "pnpm lint && pnpm typecheck && pnpm validate && pnpm test:ci",
    "prepack": "pnpm validate && pnpm test && pnpm build:release",
    "prepare": "husky",
    "precommit": "node scripts/hooks/precommit.mjs",
    "commitmsg": "commitlint --edit",
    "prepush": "node scripts/hooks/prepush.mjs",
    "lint-staged": "lint-staged"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.6.1",
    "@secretlint/secretlint-rule-preset-recommend": "^11.0.2",
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.5.0",
    "@types/semver": "^7.7.0",
    "@types/tar": "^6.1.13",
    "ajv": "8.17.1",
    "archiver": "^7.0.1",
    "eslint": "^9.9.0",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "husky": "^9.1.7",
    "jszip": "^3.10.1",
    "lint-staged": "^16.1.5",
    "micromatch": "^4.0.8",
    "picocolors": "^1.0.0",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "secretlint": "^11.0.2",
    "semver": "^7.7.2",
    "sort-package-json": "^3.4.0",
    "tar": "^7.4.3",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.4.0",
    "vitest": "^2.0.5"
  }
}
